* text=auto eol=lf

# Windows scripts
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# C/C++ sources and CMake stay LF
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.inl text eol=lf
CMakeLists.txt text eol=lf
*.cmake text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.wav binary
*.aiff binary
*.flac binary
*.zip binary
*.7z binary
*.dll binary
*.exe binary
*.lib binary
*.pdb binary
*.vst3 binary
