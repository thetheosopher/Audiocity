{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (VS2022)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "architecture": "x64",
      "cacheVariables": {
        "AUDIOCITY_ENABLE_ASIO": "ON",
        "AUDIOCITY_ASIO_SDK_DIR": "${sourceDir}/third_party/asiosdk"
      }
    },
    {
      "name": "release-selfcontained",
      "displayName": "Release Self-Contained (VS2022)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build/release-selfcontained",
      "architecture": "x64",
      "cacheVariables": {
        "AUDIOCITY_ENABLE_ASIO": "OFF",
        "AUDIOCITY_SELF_CONTAINED_RUNTIME": "ON"
      }
    },
    {
      "name": "release-selfcontained-asio",
      "displayName": "Release Self-Contained (VS2022, ASIO)",
      "inherits": "release-selfcontained",
      "binaryDir": "${sourceDir}/build/release-selfcontained-asio",
      "cacheVariables": {
        "AUDIOCITY_ENABLE_ASIO": "ON",
        "AUDIOCITY_ASIO_SDK_DIR": "${sourceDir}/third_party/asiosdk"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "displayName": "Default build",
      "configurePreset": "default",
      "configuration": "Debug"
    },
    {
      "name": "release-selfcontained",
      "displayName": "Release self-contained build",
      "configurePreset": "release-selfcontained",
      "configuration": "Release",
      "targets": [
        "Audiocity_All"
      ]
    },
    {
      "name": "release-selfcontained-asio",
      "displayName": "Release self-contained build (ASIO)",
      "configurePreset": "release-selfcontained-asio",
      "configuration": "Release",
      "targets": [
        "Audiocity_All"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Default tests",
      "configurePreset": "default"
    }
  ]
}
