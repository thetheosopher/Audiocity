{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default (VS2022)",
      "generator": "Visual Studio 17 2022",
      "binaryDir": "${sourceDir}/build",
      "architecture": "x64",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "package-debug",
      "displayName": "Package Debug (WiX)",
      "inherits": "default",
      "cacheVariables": {
        "AUDIOCITY_ENABLE_WIX_INSTALLER": "ON",
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "package-release",
      "displayName": "Package Release (WiX)",
      "inherits": "default",
      "cacheVariables": {
        "AUDIOCITY_ENABLE_WIX_INSTALLER": "ON",
        "CMAKE_BUILD_TYPE": "Release"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default",
      "displayName": "Default build",
      "configurePreset": "default"
    },
    {
      "name": "package-debug",
      "displayName": "Build MSI (Debug)",
      "configurePreset": "package-debug",
      "configuration": "Debug",
      "targets": [
        "Audiocity_All",
        "audiocity_wix_installer"
      ]
    },
    {
      "name": "package-release",
      "displayName": "Build MSI (Release)",
      "configurePreset": "package-release",
      "configuration": "Release",
      "targets": [
        "Audiocity_All",
        "audiocity_wix_installer"
      ]
    }
  ],
  "testPresets": [
    {
      "name": "default",
      "displayName": "Default tests",
      "configurePreset": "default"
    }
  ]
}
